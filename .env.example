# TikTok Analytics Studio — Environment Variables Template
# Copy this file to .env and fill in your values

# Database (SQLite — local file)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# NVIDIA NIM API key (optional but recommended)
# Get a free key at https://build.nvidia.com
# Without this: chat IA returns a friendly error, transcription falls back to local Whisper
NVIDIA_NIM_API_KEY=
